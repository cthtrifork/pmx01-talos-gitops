{
  "http": {
    "address": "0.0.0.0",
    "port": "5000"
  },
  "log": {
    "level": "info"
  },
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "retention": {
      "dryRun": false,
      "delay": "24h",
      "policies": [
        {
          "repositories": ["buildcache/**"],
          "deleteReferrers": false,
          "deleteUntagged": true,
          "keepTags": [
            {
              "patterns": ["latest"]
            },
            {
              "patterns": [".*"],
              "mostRecentlyPushedCount": 1,
              "mostRecentlyPulledCount": 1,
              "pulledWithin": "72h",
              "pushedWithin": "72h"
            }
          ]
        },
        {
          "repositories": ["**"],
          "deleteReferrers": true,
          "deleteUntagged": true,
          "keepTags": [
            {
              "patterns": ["latest"]
            },
            {
              "mostRecentlyPushedCount": 3,
              "mostRecentlyPulledCount": 3,
              "pulledWithin": "720h",
              "pushedWithin": "720h"
            }
          ]
        }
      ]
    }
  },
  "extensions": {
    "ui": {
      "enable": true
    },
    "search": {
      "enable": true
    },
    "metrics": {
      "enable": true,
      "prometheus": {
        "path": "/metrics"
      }
    },
    "sync": {
      "enable": true,
      "credentialsFile": "/etc/zot/sync/creds.json",
      "registries": [
        {
          "urls": [
            "https://mirror.gcr.io/library",
            "https://docker.io/library"
          ],
          "content": [
            {
              "prefix": "**",
              "destination": "/docker-hub-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://ghcr.io"],
          "pollInterval": "12h",
          "content": [
            {
              "prefix": "/cthtrifork/**",
              "destination": "/ghcr-private"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://ghcr.io"],
          "content": [
            {
              "prefix": "**",
              "destination": "/ghcr-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://gcr.io"],
          "content": [
            {
              "prefix": "**",
              "destination": "/gcr-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://quay.io"],
          "content": [
            {
              "prefix": "**",
              "destination": "/quay-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://registry.k8s.io"],
          "content": [
            {
              "prefix": "**",
              "destination": "/k8s-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        },
        {
          "urls": ["https://us-docker.pkg.dev"],
          "content": [
            {
              "prefix": "**",
              "destination": "/google-ar-cache"
            }
          ],
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m"
        }
      ]
    }
  }
}
