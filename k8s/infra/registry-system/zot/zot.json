    {
      "storage": {
        "rootDirectory": "/var/lib/registry"
      },
      "http": {
        "address": "0.0.0.0",
        "port": "5000"
      },
      "log": {
        "level": "debug"
      },
      "extensions": {
        "ui": {
          "enable": true
        },
        "sync": {
          "enable": true,
          "registries": [
            {
              "urls": [
                "https://docker.io/library"
              ],
              "onDemand": true,
              "tlsVerify": true,
              "maxRetries": 3,
              "retryDelay": "5m"
            },
            {
              "urls": [
                "https://ghcr.io"
              ],
              "onDemand": true,
              "tlsVerify": true,
              "maxRetries": 3,
              "retryDelay": "5m"
            }
          ]
        }
      }
    }
